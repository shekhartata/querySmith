# QuerySmith — copy to `.env` and fill in values.
# The app loads `.env` from the project root (next to `pyproject.toml`).

# --- Required for MongoDB tools (CLI, MCP, schema, indexes, explain, run) ---
MONGODB_URI=

# --- Optional: LLM-assisted rewrites (OpenAI-compatible API) ---
OPENAI_API_KEY=

# Optional: custom API base (Ollama, Azure OpenAI, LiteLLM proxy, etc.)
# QUERYSMITH_OPENAI_BASE_URL=

# Optional: model id (default gpt-4o-mini)
# QUERYSMITH_LLM_MODEL=gpt-4o-mini

# Environment label on reports: dev | uat | prod
# QUERYSMITH_ENV=dev

# Timeouts and sampling
# QUERYSMITH_DEFAULT_TIMEOUT_MS=30000
# QUERYSMITH_SAMPLE_SIZE=80
# QUERYSMITH_MAX_PIPELINE_STAGES_WARN=25
